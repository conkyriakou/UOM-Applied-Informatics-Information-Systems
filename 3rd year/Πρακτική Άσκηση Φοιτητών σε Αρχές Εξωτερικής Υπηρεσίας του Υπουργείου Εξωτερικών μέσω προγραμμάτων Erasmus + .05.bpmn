    <bpmn:messageFlow id="Flow_028zrq0" name="1.ονόματα       2. αλληλογραφία 3. δικαιολογητικά" sourceRef="Activity_1jj6gk6" targetRef="Event_18w5jn4" />
    <bpmn:textAnnotation id="TextAnnotation_0c4dtha">
      <bpmn:text>Στοιχειων( πίνακα με τις ανάλογες θέσεις και προϋποθέσεις).Προκειμένου να εκδώσει προκήρυξη (ανά ακαδημαϊκό έτος)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0kbkr6x">
      <bpmn:text>Στην Ιστοσελίδα ΥΠΕΞ</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1gt9v2n">
      <bpmn:text>Σχετικά με τα διαδικαστικά του Erasmus+ (κριτήρια επιλογής, προϋποθέσεις, γραφειοκρατικά)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1tvg0lo">
      <bpmn:text>Από φοιτητές όλων των βαθμίδων</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1bqhz0c">
      <bpmn:text>βάσει προκήρυξης του ΥΠΕ</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1wseufn">
      <bpmn:text>Από τον αρμόδιο υπάλληλο της Αρχής</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1bq9vvw">
      <bpmn:text>Πριν την κινητικότητα, συμπληρώνεται και υπογράφεται ξανά το Learning Agreement</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0buct3y">
      <bpmn:text>Μετά την κινητικότητα, συμπληρώνεται και υπογράφεται ξανά το Learning Agreement</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_13zezkd" associationDirection="None" sourceRef="Activity_10cibrc" targetRef="TextAnnotation_1bqhz0c" />
    <bpmn:association id="Association_1dpti1n" associationDirection="None" sourceRef="Activity_0rvda46" targetRef="TextAnnotation_1tvg0lo" />
    <bpmn:textAnnotation id="TextAnnotation_048kxs8">
      <bpmn:text>κριτήρια επιλογής, προϋποθέσεις, γραφειοκρατικά</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1rqpqx1">
      <bpmn:text>Για έκδοση βεβαίωσης</bpmn:text>
    </bpmn:textAnnotation>
